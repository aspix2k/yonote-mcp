YONOTE_API_TOKEN_FILE=/run/secrets/yonote-token
YONOTE_PROJECT=app
YONOTE_PROFILE=readonly
YONOTE_API_CHANNEL=stable

# Streamable HTTP. Keep MCP_HOST on loopback unless the settings below are set.
MCP_TRANSPORT=stdio
MCP_HOST=127.0.0.1
MCP_PORT=3000
# MCP_HTTP_BEARER_TOKEN=replace-with-a-long-random-value
# MCP_ALLOWED_HOSTS=mcp.example.com
# MCP_ALLOWED_ORIGINS=https://client.example.com

# File access is disabled until these paths are configured.
# YONOTE_EXPORT_DIR=/data/exports
# YONOTE_IMPORT_DIR=/data/imports
